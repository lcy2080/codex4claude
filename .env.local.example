# Optional backend routing examples for scripts/run-agent-sdk.mjs.
# Copy the variable names you need into your local shell or .env.local file.
# Do not commit real provider URLs or credential values.
# Agent mode values: codexCli, claudeCli, anthropic, openai, external.

# Global one-off provider settings.
CODEX_HARNESS_SDK=openai
CODEX_HARNESS_BASE_URL=https://provider.example/v1
OPENAI_COMPAT_API_KEY=set-in-your-shell
CODEX_HARNESS_MODEL=provider-model

# Acacia homepage smoke test settings for scripts/test-acacia-homepage.ps1.
CODEX_HARNESS_ACACIA_TEST_CWD=C:\tmp\codex4claude-acacia-site-test
CODEX_HARNESS_IMPLEMENTATION_WORKER_MODE=codexCli
CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_MODEL=gpt-5.2
# CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_PROFILE=default

# Optional sequence permission overrides. Sequence role presets keep exploration,
# review, and verification read-only unless one of these is explicitly set.
# CODEX_HARNESS_CONTEXT_EXPLORER_PERMISSION_MODE=default
# CODEX_HARNESS_IMPLEMENTATION_WORKER_PERMISSION_MODE=acceptEdits
# CODEX_HARNESS_CODE_REVIEWER_PERMISSION_MODE=default
# CODEX_HARNESS_VERIFICATION_AUDITOR_PERMISSION_MODE=default

# Agent-specific OpenAI-compatible reviewer settings. Set one MODE value per agent.
CODEX_HARNESS_CODE_REVIEWER_MODE=openai
CODEX_HARNESS_CODE_REVIEWER_SDK=openai
CODEX_HARNESS_CODE_REVIEWER_BASE_URL=https://provider.example/v1
CODEX_HARNESS_CODE_REVIEWER_API_KEY=set-in-your-shell
CODEX_HARNESS_CODE_REVIEWER_MODEL=provider-review-model

# Agent-specific Anthropic-compatible worker settings. Uncomment MODE to switch the worker off Codex CLI.
# CODEX_HARNESS_IMPLEMENTATION_WORKER_MODE=anthropic
CODEX_HARNESS_IMPLEMENTATION_WORKER_SDK=anthropic
CODEX_HARNESS_IMPLEMENTATION_WORKER_BASE_URL=https://provider.example/anthropic
CODEX_HARNESS_IMPLEMENTATION_WORKER_API_KEY=set-in-your-shell
CODEX_HARNESS_IMPLEMENTATION_WORKER_MODEL=provider-coder-model

# Force a harness agent back to local Claude CLI fallback.
# CODEX_HARNESS_CODE_REVIEWER_MODE=claudeCli
