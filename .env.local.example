# Optional external provider routing examples for scripts/run-agent-sdk.mjs.
# Copy the variable names you need into your local shell or .env.local file.
# Do not commit real provider URLs or credential values.

# Global one-off provider settings.
CODEX_HARNESS_SDK=openai
CODEX_HARNESS_BASE_URL=https://provider.example/v1
OPENAI_COMPAT_API_KEY=set-in-your-shell
CODEX_HARNESS_MODEL=provider-model

# Agent-specific OpenAI-compatible reviewer settings.
CODEX_HARNESS_CODE_REVIEWER_SDK=openai
CODEX_HARNESS_CODE_REVIEWER_BASE_URL=https://provider.example/v1
CODEX_HARNESS_CODE_REVIEWER_API_KEY=set-in-your-shell
CODEX_HARNESS_CODE_REVIEWER_MODEL=provider-review-model

# Agent-specific Anthropic-compatible worker settings.
CODEX_HARNESS_IMPLEMENTATION_WORKER_SDK=anthropic
CODEX_HARNESS_IMPLEMENTATION_WORKER_BASE_URL=https://provider.example/anthropic
CODEX_HARNESS_IMPLEMENTATION_WORKER_API_KEY=set-in-your-shell
CODEX_HARNESS_IMPLEMENTATION_WORKER_MODEL=provider-coder-model

# Optional Codex CLI backend model/profile settings for a manifest entry with mode: "codexCli".
# Select Codex CLI mode in config/agent-providers.json, not with a CODEX_HARNESS_*_MODE env var.
CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_MODEL=gpt-5.2
CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_PROFILE=default
