{
  "agents": {
    "codex-main": {
      "sdk": "anthropic",
      "sdkEnv": "CODEX_HARNESS_CODEX_MAIN_SDK",
      "mode": "claudeCli",
      "claudeAgent": "codex-harness:codex-main",
      "model": "sonnet",
      "effort": "high"
    },
    "context-explorer": {
      "sdk": "anthropic",
      "sdkEnv": "CODEX_HARNESS_CONTEXT_EXPLORER_SDK",
      "mode": "external",
      "baseUrlEnv": "CODEX_HARNESS_CONTEXT_EXPLORER_BASE_URL",
      "credential": {
        "type": "apiKey",
        "env": "CODEX_HARNESS_CONTEXT_EXPLORER_API_KEY"
      },
      "modelEnv": "CODEX_HARNESS_CONTEXT_EXPLORER_MODEL",
      "fallbackModel": "haiku",
      "effort": "low"
    },
    "implementation-worker": {
      "mode": "codexCli",
      "model": "gpt-5.2",
      "modelEnv": "CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_MODEL",
      "codexProfileEnv": "CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_PROFILE",
      "codexModelEnv": "CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_MODEL",
      "fallbackModel": "sonnet",
      "effort": "medium"
    },
    "codex-implementation-worker": {
      "mode": "codexCli",
      "model": "gpt-5.2",
      "modelEnv": "CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_MODEL",
      "codexProfileEnv": "CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_PROFILE",
      "codexModelEnv": "CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_MODEL",
      "fallbackModel": "sonnet",
      "effort": "medium"
    },
    "code-reviewer": {
      "sdk": "anthropic",
      "sdkEnv": "CODEX_HARNESS_CODE_REVIEWER_SDK",
      "mode": "external",
      "baseUrlEnv": "CODEX_HARNESS_CODE_REVIEWER_BASE_URL",
      "credential": {
        "type": "apiKey",
        "env": "CODEX_HARNESS_CODE_REVIEWER_API_KEY"
      },
      "modelEnv": "CODEX_HARNESS_CODE_REVIEWER_MODEL",
      "fallbackModel": "sonnet",
      "effort": "high"
    },
    "verification-auditor": {
      "sdk": "anthropic",
      "sdkEnv": "CODEX_HARNESS_VERIFICATION_AUDITOR_SDK",
      "mode": "external",
      "baseUrlEnv": "CODEX_HARNESS_VERIFICATION_AUDITOR_BASE_URL",
      "credential": {
        "type": "apiKey",
        "env": "CODEX_HARNESS_VERIFICATION_AUDITOR_API_KEY"
      },
      "modelEnv": "CODEX_HARNESS_VERIFICATION_AUDITOR_MODEL",
      "model": "opus",
      "fallbackModel": "opus",
      "effort": "max"
    }
  }
}
