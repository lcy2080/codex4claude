{
  "agents": {
    "codex-main": {
      "sdk": "anthropic",
      "sdkEnv": "CODEX_HARNESS_CODEX_MAIN_SDK",
      "modeEnv": "CODEX_HARNESS_CODEX_MAIN_MODE",
      "mode": "claudeCli",
      "claudeAgent": "codex-harness:codex-main",
      "model": "sonnet",
      "effort": "high"
    },
    "context-explorer": {
      "sdk": "anthropic",
      "sdkEnv": "MINIMAX_SDK",
      "modeEnv": "CODEX_HARNESS_CONTEXT_EXPLORER_MODE",
      "mode": "external",
      "baseUrlEnv": "MINIMAX_BASE_URL",
      "credential": {
        "type": "apiKey",
        "env": "MINIMAX_API_KEY"
      },
      "model": "provider-fast-model",
      "modelEnv": "MINIMAX_FAST_MODEL",
      "codexModelEnv": "CODEX_HARNESS_CONTEXT_EXPLORER_CODEX_MODEL",
      "codexProfileEnv": "CODEX_HARNESS_CONTEXT_EXPLORER_CODEX_PROFILE",
      "fallbackModel": "haiku",
      "effort": "low"
    },
    "implementation-worker": {
      "sdk": "anthropic",
      "sdkEnv": "MINIMAX_SDK",
      "modeEnv": "CODEX_HARNESS_IMPLEMENTATION_WORKER_MODE",
      "mode": "codexCli",
      "baseUrlEnv": "MINIMAX_BASE_URL",
      "credential": {
        "type": "apiKey",
        "env": "MINIMAX_API_KEY"
      },
      "model": "gpt-5.2",
      "modelEnv": "MINIMAX_CODER_MODEL",
      "codexProfileEnv": "CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_PROFILE",
      "codexModelEnv": "CODEX_HARNESS_IMPLEMENTATION_WORKER_CODEX_MODEL",
      "fallbackModel": "sonnet",
      "effort": "medium"
    },
    "code-reviewer": {
      "sdk": "anthropic",
      "sdkEnv": "CODEX_PROVIDER_SDK",
      "modeEnv": "CODEX_HARNESS_CODE_REVIEWER_MODE",
      "mode": "external",
      "baseUrlEnv": "CODEX_PROVIDER_BASE_URL",
      "credential": {
        "type": "apiKey",
        "env": "CODEX_PROVIDER_API_KEY"
      },
      "model": "provider-review-model",
      "modelEnv": "CODEX_PROVIDER_REVIEW_MODEL",
      "codexModelEnv": "CODEX_HARNESS_CODE_REVIEWER_CODEX_MODEL",
      "codexProfileEnv": "CODEX_HARNESS_CODE_REVIEWER_CODEX_PROFILE",
      "fallbackModel": "sonnet",
      "effort": "high"
    },
    "openai-context-explorer": {
      "sdk": "openai",
      "sdkEnv": "OPENAI_COMPAT_SDK",
      "modeEnv": "CODEX_HARNESS_OPENAI_CONTEXT_EXPLORER_MODE",
      "mode": "external",
      "baseUrlEnv": "OPENAI_COMPAT_BASE_URL",
      "credential": {
        "type": "apiKey",
        "env": "OPENAI_COMPAT_API_KEY"
      },
      "model": "provider-fast-model",
      "modelEnv": "OPENAI_COMPAT_FAST_MODEL",
      "fallbackModel": "haiku",
      "effort": "low"
    },
    "zai-code-reviewer": {
      "sdk": "openai",
      "sdkEnv": "ZAI_CODE_REVIEWER_SDK",
      "modeEnv": "CODEX_HARNESS_ZAI_CODE_REVIEWER_MODE",
      "mode": "external",
      "baseUrlEnv": "ZAI_CODE_REVIEWER_BASE_URL",
      "credential": {
        "type": "apiKey",
        "env": "ZAI_CODE_REVIEWER_API_KEY"
      },
      "model": "provider-review-model",
      "modelEnv": "ZAI_CODE_REVIEWER_MODEL",
      "fallbackModel": "sonnet",
      "effort": "high"
    },
    "verification-auditor": {
      "sdk": "anthropic",
      "sdkEnv": "CODEX_HARNESS_VERIFICATION_AUDITOR_SDK",
      "modeEnv": "CODEX_HARNESS_VERIFICATION_AUDITOR_MODE",
      "mode": "claudeCli",
      "claudeAgent": "verification-auditor",
      "model": "opus",
      "effort": "max"
    }
  }
}
